generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Compte admin du dashboard
model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  Session[]
}

// Sessions persistantes pour Railway (pas de mémoire volatile)
model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

// Configuration du robot (stockée en base, éditable via dashboard)
model BotConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

// Chaque conversation WhatsApp en cours
model Conversation {
  id          String   @id @default(uuid())
  phone       String   @unique
  state       String   @default("IDLE")
  data        String   @default("{}")   // JSON des données collectées
  startedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  orders      Order[]
}

// Commande finalisée
model Order {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  // Informations client
  firstName      String
  lastName       String
  phone          String
  email          String?
  address        String?
  cardType       String       @default("VISA_CLASSIC")
  extraData      String       @default("{}")  // JSON champs additionnels

  // Google Drive
  driveFolderId  String?
  driveFolderUrl String?

  // Statut
  status         String       @default("PENDING")  // PENDING | PROCESSING | DONE | CANCELLED

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  documents      Document[]
}

// Documents envoyés par le client (photos pièce d'identité, etc.)
model Document {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  fileName    String
  mimeType    String
  driveFileId String?
  source      String   @default("WHATSAPP")  // WHATSAPP | FORM
  createdAt   DateTime @default(now())
}

// Log des messages WhatsApp pour débogage
model MessageLog {
  id        String   @id @default(uuid())
  phone     String
  direction String   // IN | OUT
  content   String
  type      String   @default("text")  // text | image | document
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([createdAt])
}
